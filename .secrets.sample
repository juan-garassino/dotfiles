# ~/.secrets.sample — the keys/credentials this environment expects.
# Copy to ~/.secrets, fill in real values, then: chmod 600 ~/.secrets
# ~/.secrets is sourced by zshrc at startup and is NEVER committed to any repo.

# Secrets — sourced by ~/.zshrc. Keep chmod 600. Copy this file to each machine.
export OPENAI_API_KEY=""
export ANTHROPIC_API_KEY=""
export NVIDIA_API_KEY=""
export PERPLEXITY_API_KEY=""

# Azure OpenAI — migrated from ~/.claude/settings.json on 2026-06-21 (achievementsai resource)
export AZURE_OPENAI_API_KEY=""
export AZURE_OPENAI_ENDPOINT=""
export AZURE_OPENAI_API_VERSION=""
export AZURE_OPENAI_CHAT_DEPLOYMENT=""
