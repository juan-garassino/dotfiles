[color]
  branch = auto
  diff = auto
  interactive = auto
  status = auto
  ui = auto

[color "branch"]
  current = green
  remote = yellow

[core]
  pager = less -FRSX
  editor = code
  autocrlf = input
  whitespace = trailing-space,space-before-tab

[user]
  email = juan.garassino@gmail.com
  name = Juan Garassino

[alias]
  co = checkout
  st = status -sb
  br = branch
  ci = commit
  fo = fetch origin
  d = !git --no-pager diff
  dt = difftool
  stat = !git --no-pager diff --stat

  # Clean merged branches
  sweep = !git branch --merged master | grep -v 'master$' | xargs git branch -d && git remote prune origin

  # Pretty log
  lg = log --graph --all --pretty=format:'%Cred%h%Creset - %s %Cgreen(%cr) %C(bold blue)%an%Creset %C(yellow)%d%Creset'

  # Compact log with dates
  ll = log --pretty=format:'%C(yellow)%h%Creset %ad | %s%d [%an]' --date=short

  # Serve local repo
  serve = !git daemon --reuseaddr --verbose --base-path=. --export-all ./.git

  m = checkout master

  # Removes a file from the index
  unstage = reset HEAD --

  # Undo last commit but keep changes staged
  undo = reset --soft HEAD~1

  # Show last commit
  last = log -1 HEAD --stat

  # List all aliases
  aliases = config --get-regexp alias

  # Stash with a message
  ss = stash save

  # Show stash list
  sl = stash list

  # Apply and drop stash
  sp = stash pop

  # Show contributors
  contributors = shortlog --summary --numbered --email

  # Find commits by message
  find = log --all --pretty=format:'%Cred%h%Creset - %s %Cgreen(%cr) %C(bold blue)%an%Creset' --grep

[help]
  autocorrect = 1

[push]
  default = simple
  autoSetupRemote = true

[branch "master"]
  mergeoptions = --no-edit

[pull]
  rebase = false

[rebase]
  autoStash = true

[diff]
  colorMoved = zebra

[merge]
  conflictstyle = diff3

[fetch]
  prune = true

[filter "lfs"]
  required = true

# Identity by directory. Order matters: later includes override earlier
# ones, so everything under ~/Code/ is personal EXCEPT 002-engenious/.
# Rename-proof: no per-folder personal rules to rot when folders renumber.
[includeIf "gitdir:~/Code/"]
  path = ~/.gitconfig-personal
[includeIf "gitdir:~/Code/002-engenious/"]
  path = ~/.gitconfig-work

[init]
  defaultBranch = main
[credential "https://github.com"]
	helper = 
	helper = !/usr/local/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/local/bin/gh auth git-credential
