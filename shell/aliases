###############################################################################
# 🔍 Search & Filesystem
###############################################################################
alias grep="grep --color=auto"
alias fhere="find . -name"
alias duh="du -sh * | sort -rh | head -20"
alias dfh="df -h"
alias rmnm="find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && echo '🧹 node_modules removed'"
