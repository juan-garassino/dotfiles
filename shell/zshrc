# pyenv (Python) — lazy-loaded. `eval "$(pyenv init -)"` and `eval "$(pyenv
# virtualenv-init -)"` together are ~200-400ms at every shell start; deferred
# until the user invokes pyenv/python/python3/pip/pip3. The `autoenv_activate`
# cd-hook below calls `python` and `pyenv` directly, so the first `cd` after
# shell open triggers the load — identical end behavior, just shifted.
export PYENV_VIRTUALENV_DISABLE_PROMPT=1
if type -a pyenv > /dev/null 2>&1; then
  _pyenv_lazy_load() {
    unset -f pyenv python python3 _pyenv_lazy_load 2>/dev/null
    eval "$(command pyenv init -)"
    eval "$(command pyenv virtualenv-init -)"
  }
  # Skip `pip` / `pip3` here — they're aliased by oh-my-zsh's common-aliases plugin,
  # so trying to define them as functions throws "defining function based on alias".
  # Defensive: Claude Code's shell snapshot drops `_`-prefixed helpers — guard so a
  # dropped helper falls through to the real binary instead of recursing forever.
  for _cmd in pyenv python python3; do
    eval "${_cmd}() { if typeset -f _pyenv_lazy_load >/dev/null 2>&1; then _pyenv_lazy_load; ${_cmd} \"\$@\"; else command ${_cmd} \"\$@\"; fi }"
  done
  unset _cmd
fi

# nvm (Node.js) — lazy-loaded. Sourcing nvm.sh is typically the single biggest
# chunk of shell-startup cost (~150-300ms). The whole chain — nvm.sh,
# bash_completion, the load-nvmrc auto-hook, and the initial nvmrc check — is
# deferred until the user invokes nvm/node/npm/npx/yarn/pnpm/corepack.
export NVM_DIR="$HOME/.nvm"
_nvm_lazy_load() {
  unset -f nvm node npm npx yarn pnpm corepack _nvm_lazy_load
  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
  [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
  autoload -U add-zsh-hook
  load-nvmrc() {
    if nvm -v &> /dev/null; then
      local node_version="$(nvm version)"
      local nvmrc_path="$(nvm_find_nvmrc)"
      if [ -n "$nvmrc_path" ]; then
        local nvmrc_node_version=$(nvm version "$(cat "${nvmrc_path}")")
        if [ "$nvmrc_node_version" = "N/A" ]; then
          nvm install
        elif [ "$nvmrc_node_version" != "$node_version" ]; then
          nvm use --silent
        fi
      elif [ "$node_version" != "$(nvm version default)" ]; then
        nvm use default --silent
      fi
    fi
  }
  add-zsh-hook chpwd load-nvmrc
  load-nvmrc
}
# Defensive: Claude Code's shell snapshot drops `_`-prefixed helpers — guard so a
# dropped helper falls through to the real binary instead of recursing forever.
for _cmd in nvm node npm npx yarn pnpm corepack; do
  eval "${_cmd}() { if typeset -f _nvm_lazy_load >/dev/null 2>&1; then _nvm_lazy_load; ${_cmd} \"\$@\"; else command ${_cmd} \"\$@\"; fi }"
done
unset _cmd

