# freezeenv → save current deps to requirements.txt
freezeenv() {
  if [ -z "$VIRTUAL_ENV" ]; then
    echo "⚠️  No active venv to freeze."
    return 1
  fi
  uv pip freeze > requirements.txt
  echo "📄 Saved requirements.txt from current environment."
}

# syncenv → sync environment with requirements.txt
syncenv() {
  if [ ! -f requirements.txt ]; then
    echo "⚠️  No requirements.txt found."
    return 1
  fi
  uv pip sync requirements.txt
  echo "🔄 Synced environment with requirements.txt."
}

# envcheck → compare .env vs .env.example and show missing vars
# Usage: envcheck
envcheck() {
  if [ ! -f ".env.example" ]; then
    echo "⚠️  No .env.example found in current directory."
    return 1
  fi
  if [ ! -f ".env" ]; then
    echo "⚠️  No .env found — you may need to create one from .env.example"
    return 1
  fi

  local missing=()
  while IFS= read -r line; do
    # skip comments and empty lines
    [[ "$line" =~ ^#.*$ || -z "$line" ]] && continue
    local key="${line%%=*}"
    if ! grep -q "^${key}=" .env 2>/dev/null; then
      missing+=("$key")
    fi
  done < .env.example

  if [ ${#missing[@]} -eq 0 ]; then
    echo "✅ .env is complete — all keys from .env.example are present."
  else
    echo "❌ Missing keys in .env:"
    for k in "${missing[@]}"; do
      echo "  - $k"
    done
  fi
}

# pyswitch → interactively select and switch Python version
# Usage: pyswitch
pyswitch() {
  local versions
  versions=$(pyenv versions --bare)

  if [ -z "$versions" ]; then
    echo "⚠️  No pyenv versions installed."
    return 1
  fi

  echo "🐍 Available Python versions:"
  local i=1
  local -a version_array
  while IFS= read -r ver; do
    echo "  $i) $ver"
    version_array+=("$ver")
    i=$((i + 1))
  done <<< "$versions"

  echo -n "Select version (or press Enter to cancel): "
  read -r choice

  if [[ ! "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt ${#version_array[@]} ]; then
    echo "↩️  Cancelled."
    return 1
  fi

  # zsh arrays are 1-indexed — $choice maps directly, no off-by-one
  local selected="${version_array[$choice]}"
  deactivate 2>/dev/null || true
  pyenv shell "$selected"
  echo "✅ Switched to Python $selected (🐍 $(python --version 2>/dev/null))"
}

# pkgupdate → upgrade specific packages and update requirements.txt
# Usage: pkgupdate numpy pandas
pkgupdate() {
  if [ $# -eq 0 ]; then
    echo "⚠️  Usage: pkgupdate <package_names...>"
    echo "  Example: pkgupdate numpy pandas requests"
    return 1
  fi

  if [ -z "$VIRTUAL_ENV" ]; then
    echo "⚠️  No active venv. Activate one first."
    return 1
  fi

  echo "📦 Upgrading packages: $@"
  uv pip install --upgrade "$@" || return 1

  echo "💾 Updating requirements.txt..."
  uv pip freeze > requirements.txt
  echo "✅ Updated requirements.txt"
}

# venvclean → interactively remove unused .venv folders
# Usage: venvclean
venvclean() {
  local venvs=()
  local sizes=()

  for v in .venv*; do
    if [ -d "$v" ]; then
      local size
      size=$(du -sh "$v" 2>/dev/null | awk '{print $1}')
      venvs+=("$v")
      sizes+=("$size")
    fi
  done

  if [ ${#venvs[@]} -eq 0 ]; then
    echo "✅ No local venvs to clean."
    return 0
  fi

  echo "🧹 Local venvs found:"
  # zsh-native iteration (the old ${!venvs[@]} / read -a were bash-only)
  local i
  for ((i = 1; i <= ${#venvs[@]}; i++)); do
    echo "  $i) ${venvs[$i]} (${sizes[$i]})"
  done

  echo -n "Enter numbers to delete (space-separated, or Enter to skip): "
  local -a choices
  read -rA choices

  if [ ${#choices[@]} -eq 0 ]; then
    echo "↩️  Cancelled."
    return 0
  fi

  local choice
  for choice in "${choices[@]}"; do
    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#venvs[@]} ]; then
      local target="${venvs[$choice]}"
      echo "🗑️  Removing $target..."
      rm -rf "$target"
    fi
  done
  echo "✅ Cleanup done."
}

# dev-reset → completely reset environment (for debugging)
# Usage: dev-reset
dev-reset() {
  echo "⚠️  This will deactivate all venvs and reset pyenv..."
  echo -n "Are you sure? [y/N] "
  read -r confirm

  if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    echo "↩️  Cancelled."
    return 0
  fi

  deactivate 2>/dev/null || true
  pyenv deactivate 2>/dev/null || true

  if [ -f ".python-version" ]; then
    rm .python-version
    echo "  ✓ Removed .python-version"
  fi

  if [ -d ".venv" ]; then
    rm -rf .venv
    echo "  ✓ Removed .venv"
  fi

  echo "🔄 Environment reset. Next cd will auto-detect."
}


#######################################################################
# 🤖 autoenv → auto-activate .venv or pyenv on cd
#######################################################################
autoenv_activate() {
  if [ -f ".venv/bin/activate" ]; then
    if [ "$VIRTUAL_ENV" != "$(pwd)/.venv" ]; then
      deactivate 2>/dev/null || true
      pyenv deactivate 2>/dev/null || true
      source .venv/bin/activate
      # echoes only in interactive shells — keeps Claude Code / script output clean
      [[ -o interactive ]] && echo "▶ Activated .venv with uv (🐍 $(python --version 2>/dev/null))"
    fi
    return
  fi

  if [ -f ".python-version" ]; then
    local ver
    ver=$(cat .python-version)

    if pyenv versions --bare | grep -qx "$ver"; then
      if [ "$VIRTUAL_ENV" != "$(pyenv prefix "$ver")" ]; then
        deactivate 2>/dev/null || true
        pyenv activate "$ver"
        [[ -o interactive ]] && echo "▶ Activated pyenv virtualenv: $ver (🐍 $(python --version 2>/dev/null))"
      fi
      return
    fi

    if [[ "$ver" =~ ^[0-9]+\.[0-9]+(\.[0-9]+)?$ ]]; then
      deactivate 2>/dev/null || true
      pyenv shell "$ver"
      [[ -o interactive ]] && echo "▶ Using pyenv Python $ver (no venv) (🐍 $(python --version 2>/dev/null))"
      return
    fi

    [[ -o interactive ]] && echo "⚠️  .python-version contains invalid entry: '$ver' — using global pyenv"
  fi

  # uv-first: no project env here → drop to the global pyenv 'sandbox' playground
  if pyenv virtualenvs --bare 2>/dev/null | grep -qx "sandbox"; then
    if [ "${VIRTUAL_ENV:t}" != "sandbox" ]; then
      deactivate 2>/dev/null || true
      pyenv deactivate 2>/dev/null || true
      pyenv activate sandbox 2>/dev/null || true
      [[ -o interactive ]] && echo "▶ No project env — using global sandbox (🐍 $(python --version 2>/dev/null))"
    fi
  else
    deactivate 2>/dev/null || true
    pyenv deactivate 2>/dev/null || true
    [[ -o interactive ]] && echo "▶ No project env — using global pyenv (🐍 $(python --version 2>/dev/null))"
  fi
  return 0
}

#######################################################################
# 🐙 gh auto-switch → work account inside 002-engenious, personal elsewhere
#######################################################################
# Reads the active account from hosts.yml (fast file read); only execs
# `gh auth switch` (~200ms) when actually crossing the context boundary.
# Git COMMIT identity is separate (gitconfig includeIf) — this switches
# only the gh CLI (API/PR) account.
# NOTE: no leading underscore on purpose — Claude Code's shell snapshot
# drops `_`-prefixed functions, and cd() below calls this.
gh_auto_switch() {
  (( $+commands[gh] )) || return 0
  local want have
  case "$PWD" in
    "$HOME/Code/002-engenious"*) want="j-garassino-engenious" ;;
    *)                           want="juan-garassino" ;;
  esac
  have=$(awk '$1 == "user:" {print $2; exit}' ~/.config/gh/hosts.yml 2>/dev/null)
  if [ -n "$have" ] && [ "$have" != "$want" ]; then
    if gh auth switch --user "$want" >/dev/null 2>&1; then
      [[ -o interactive ]] && echo "🐙 gh → $want"
    fi
  fi
  return 0
}

cd() {
  builtin cd "$@" || return
  autoenv_activate
  (( ${+functions[gh_auto_switch]} )) && gh_auto_switch
}

