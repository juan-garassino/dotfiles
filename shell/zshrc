  compdef _kubectl_completion_lazy kubectl
fi
if [[ $commands[minikube] ]]; then
  _minikube_completion_lazy() {
    unfunction _minikube_completion_lazy
    source <(command minikube completion zsh)
  }
  compdef _minikube_completion_lazy minikube
fi

