# Secrets — keys live in ~/.secrets (chmod 600, outside any repo). Never commit.
.secrets
!.secrets.sample
*.secret
*.env
.env
.env.*
!.env.example
*-*.json.key
*service-account*.json

# Claude Code local / runtime
claude/settings.local.json
claude/**/.DS_Store

# OS / editor noise
.DS_Store

# Backups & logs
*.backup
*.tmp
*.log

# Generated artifacts (regenerated by custom_scripts)
custom_scripts/repos.json
custom_scripts/dashboard_out.html
